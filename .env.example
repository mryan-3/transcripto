# Database configuration for Prisma (@transcripto/db)
DATABASE_URL="postgresql://postgres:password@localhost:5432/transcripto?schema=public"

# API configuration (apps/api)
PORT=4000

# Redis connection (packages/jobs)
REDIS_URL="redis://localhost:6379"

# Transcription Provider: "local" or "openai"
TRANSCRIPTION_PROVIDER="local"

# Settings for Strategy: "local" (whisper.cpp)
WHISPER_BIN_PATH="/absolute/path/to/whisper-cli"
WHISPER_MODEL_PATH="/absolute/path/to/ggml-base.en.bin"

# Settings for Strategy: "openai" (OpenRouter or standard OpenAI)
OPENAI_API_KEY="sk-..."
OPENAI_BASE_URL="https://openrouter.ai/api/v1"
OPENAI_MODEL="nvidia/nemotron-3-ultra-550b-a55b:free"
